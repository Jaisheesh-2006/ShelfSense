# ShelfSense — example environment configuration.
# Copy to `.env` and fill in. NEVER commit real secrets. (CLAUDE.md: no hardcoded secrets.)

# --- General ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Event stream (Kafka-compatible) ---
STREAM_BOOTSTRAP_SERVERS=localhost:9092
STREAM_TOPIC_DETECTIONS=detection.created
STREAM_TOPIC_TRACKS=track.updated
STREAM_TOPIC_SESSIONS=session.events
STREAM_TOPIC_METRICS=metric.computed

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shelfsense
POSTGRES_USER=shelfsense
POSTGRES_PASSWORD=changeme

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Detector ---
YOLO_MODEL=yolov8n.pt
DETECTION_CONFIDENCE=0.4

# --- Business rule thresholds (see docs/wiki/BUSINESS_RULES.md) ---
MIN_ZONE_DWELL_MS=2000
MIN_ENGAGEMENT_DWELL_MS=3000
SESSION_TIMEOUT_MS=30000

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
