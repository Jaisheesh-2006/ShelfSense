# ShelfSense — example environment configuration.
# Copy to `.env` and fill in. NEVER commit real secrets. (CLAUDE.md: no hardcoded secrets.)

# --- General ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Event stream (Kafka-compatible) ---
STREAM_BOOTSTRAP_SERVERS=localhost:9092
STREAM_TOPIC_DETECTIONS=detection.created
STREAM_TOPIC_TRACKS=track.updated
STREAM_TOPIC_SESSIONS=session.events
STREAM_TOPIC_METRICS=metric.computed

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=shelfsense
POSTGRES_USER=shelfsense
POSTGRES_PASSWORD=changeme

# --- Detector ---
YOLO_MODEL=yolov8n.pt
DETECTION_CONFIDENCE=0.35          # validated on CAM3 corridor traffic (Slice 2.2)
PERSON_CLASS_ID=0                  # COCO 'person'
CCTV_DIR=/data/cctv               # where CCTV clips are mounted in the container
DETECTOR_SAMPLE_FPS=5.0           # frames/sec sampled for plain detection
DETECTOR_MAX_FRAMES=0             # cap frames per clip (0 = whole clip)

# --- Tracking / behavioural events (Slice 2.2) ---
TRACKER_SAMPLE_FPS=5.0            # frames/sec sampled for tracking (ADR-0019: 10->5 for speed)
DETECTOR_IMGSZ=480               # YOLO inference size; lower = faster on CPU (ADR-0019, mult. of 32)
TRACKER_CFG=bytetrack.yaml        # Ultralytics built-in tracker config
CROSSING_CONFIRM_FRAMES=2         # frames a line-side flip must persist (flicker debounce)
EVENTS_JSONL_PATH=/data/events/behavior.jsonl   # where the pipeline writes behavioural events
CLIP_START_ISO=2026-04-10T20:10:00+05:30        # clip wall-clock start -> absolute UTC timestamp

# --- Detector -> API auto-feed (Slice 2.8 — see DECISIONS ADR-0015) ---
API_BASE_URL=http://api:8000      # API base the detector POSTs events to (http://localhost:8000 locally)
DETECTOR_POST_TO_API=true         # auto-POST emitted events to /events/ingest (no manual replay)
INGEST_BATCH_SIZE=500             # <= the API's per-request cap
INGEST_WAIT_S=60.0                # max seconds to wait for the API to be ready before posting
INGEST_MAX_RETRIES=5              # per-batch POST retries (backoff) before falling back to JSONL-onlys

# --- Business rule thresholds (see docs/wiki/BUSINESS_RULES.md) ---
MIN_ZONE_DWELL_MS=2000
MIN_ENGAGEMENT_DWELL_MS=3000
SESSION_TIMEOUT_MS=30000
REENTRY_WINDOW_MS=120000
ZONE_DWELL_INTERVAL_MS=30000      # re-emit ZONE_DWELL every N ms of continuous presence
ZONE_EXIT_GRACE_MS=2000           # absence beyond this ends a zone visit (ZONE_EXIT)

# --- Re-ID + staff (Slices 2.4 / 2.4b — see DECISIONS ADR-0008/0009) ---
REID_MAX_DISTANCE=0.55            # max appearance (cosine) distance to call two tracks one person
REID_REENTRY_MIN_GAP_MS=5000      # absence before a re-matched visitor counts as REENTRY
STAFF_DARKNESS_THRESHOLD=0.50     # mean dark-uniform score >= this => is_staff (black uniform)
STAFF_DARK_V_MAX=70               # HSV Value (0-255) <= this => a pixel is "dark"/near-black
STAFF_PRESENCE_FALLBACK=false     # also flag long-present tracks as staff (off by default)
STAFF_MIN_PRESENCE_MS=90000       # presence-fallback threshold (used only if enabled above)

# --- Vision-Language Model (Slice 2.9 — see DECISIONS ADR-0027) ---
# OPTIONAL. Off by default so `docker compose up` needs no key/network (acceptance-gate safe). Turn
# on ONLY for the offline pre-generation run that builds the committed events; verdicts are cached
# (VLM_CACHE_PATH) so re-runs are free and the reviewer's run makes zero API calls.
VLM_ENABLED=false                 # master switch; true only for the offline event-generation run
VLM_PROVIDER=gemini               # only "gemini" implemented
GEMINI_API_KEY=                   # SECRET — your Google AI Studio key; required when VLM_ENABLED=true
VLM_MODEL=gemini-2.0-flash        # any fast multimodal Gemini model
VLM_CLASSIFY_STAFF=true           # use the VLM for staff/customer (else dark-uniform heuristic only)
VLM_CLASSIFY_ZONE=true            # use the VLM to label product-camera zones (else static primary_zone)
VLM_STAFF_MIN_CONFIDENCE=0.55     # below this, keep the heuristic verdict
VLM_ZONE_MIN_CONFIDENCE=0.55      # below this, keep the static zone
VLM_CACHE_PATH=/data/vlm/vlm_cache.json   # persistent verdict cache (commit it for reproducible replay)
VLM_ZONE_FRAME_FRACTION=0.4       # where in the clip to grab the representative zone frame (0..1)
VLM_TIMEOUT_S=30.0                # per-call timeout
VLM_MAX_RETRIES=2                 # per-call retries before falling back to the heuristic

# --- POS correlation / conversion (Slice 2.5 — see DECISIONS ADR-0012) ---
POS_CSV_PATH=/data/pos/pos_transactions.csv  # mounted sales CSV (globs the dir if this name is absent)
STORE_TIMEZONE=Asia/Kolkata       # store-local tz; order_date+order_time -> UTC
POS_CORRELATION_WINDOW_MS=300000  # 5-min billing-zone-before-transaction window
CONVERSION_LOW_SAMPLE_THRESHOLD=20  # < N unique visitors => data_confidence "low"
POS_DEMO_ALIGNMENT=false          # demo-only alignment of a representative visitor to a real sale

# --- Anomalies (Slice 2.7 — see docs/wiki/BUSINESS_RULES.md) ---
ANOMALY_QUEUE_DEPTH_WARN=3         # checkout customers (staff excluded) => WARN queue spike
ANOMALY_QUEUE_DEPTH_CRITICAL=5     # => CRITICAL queue spike
ANOMALY_CONVERSION_BASELINE=0.15   # documented target rate (no 7-day history); drop fires only at ok confidence
ANOMALY_CONVERSION_DROP_PCT=0.30   # fire when conversion <= baseline * (1 - this)
ANOMALY_DEAD_ZONE_MINUTES=30       # zone silent this long during open hours => dead zone
STORE_OPEN_HOUR=12                 # store-local trading window (for dead-zone), POS spans ~12:15-21:40
STORE_CLOSE_HOUR=22

# --- Health / feed freshness (Slice 2.7) ---
HEALTH_STALE_FEED_MINUTES=10       # feed lag beyond which a store is STALE_FEED
HEALTH_STRICT_NOW=false            # false: freshness vs latest ingested event (recording-relative); true: vs real now

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=*          # browser origins allowed to call the API (the dashboard); "*" = any
STORES=ST1008:Brigade Bangalore,ST1009:Store 2   # stores the dashboard switcher lists (id:name pairs)
